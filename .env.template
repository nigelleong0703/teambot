# -----------------------------
# Provider manager (agent role)
# -----------------------------
AGENT_PROVIDER=openai-compatible
AGENT_MODEL=
AGENT_API_KEY=
AGENT_BASE_URL=https://api.openai.com/v1
AGENT_TIMEOUT_SECONDS=20
AGENT_MAX_ATTEMPTS=2
AGENT_FALLBACKS_JSON=[]
# Optional provider fallback keys (used when AGENT_API_KEY is empty)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=

# -----------------------------
# Agent home
# -----------------------------
# TeamBot treats AGENT_HOME as the agent's only working root.
# Derived paths:
# - prompt files: $AGENT_HOME/system/{AGENTS,SOUL,PROFILE}.md
# - tool work dir: $AGENT_HOME/work
# - shared skill docs: ~/.teambot/skills
# - agent-local skill docs: $AGENT_HOME/skills
# - dynamic skill plugins: $AGENT_HOME/system/skills
AGENT_HOME=~/.teambot/agents/default

# -----------------------------
# Tool runtime profile
# -----------------------------
# Recommended default for local testing:
# minimal | external_operation | full
TOOLS_PROFILE=external_operation
TOOLS_NAMESAKE_STRATEGY=skip
ENABLE_ECHO_TOOL=false
ENABLE_EXEC_TOOL=false
EXEC_TIMEOUT_SECONDS=20
BROWSER_TIMEOUT_SECONDS=10
TOOL_OUTPUT_MAX_CHARS=4000

# -----------------------------
# MCP runtime
# -----------------------------
MCP_ENABLED=false
MCP_SERVERS_JSON=[]

# -----------------------------
# Policy gate
# -----------------------------
ALLOW_HIGH_RISK_ACTIONS=false
HIGH_RISK_ALLOWED_ACTIONS=
