# -----------------------------
# Canonical runtime config
# -----------------------------
RUNTIME_CONFIG_FILE=./config/config.json

# Secrets referenced by config/config.json via ${ENV_VAR} substitution.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=

# -----------------------------
# Agent home
# -----------------------------
# TeamBot treats AGENT_HOME as the agent's only working root.
# Derived paths:
# - prompt files: $AGENT_HOME/system/{AGENTS,SOUL,PROFILE}.md
# - tool work dir: $AGENT_HOME/work
# - runtime store db: $AGENT_HOME/state/teambot.sqlite
# - shared skill docs: ~/.teambot/skills
# - agent-local skill docs: $AGENT_HOME/skills
# - dynamic skill plugins: $AGENT_HOME/system/skills
AGENT_HOME=${HOME}/.teambot/agents/default

# Optional legacy/override envs remain supported in code for compatibility:
# - AGENT_*
# - SUMMARY_*
# - TOOLS_*
# - MCP_*
# - ALLOW_HIGH_RISK_ACTIONS / HIGH_RISK_ALLOWED_ACTIONS
# Prefer config/config.json instead of those envs for new setups.

# -----------------------------
# Channel SDK credentials
# -----------------------------
# Slack Bolt
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# python-telegram-bot webhook mode
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# pywa / WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=

# Lark / Feishu event subscriptions
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Discord interactions
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
