# -----------------------------
# Provider manager (agent role)
# -----------------------------
AGENT_PROVIDER=openai-compatible
AGENT_MODEL=
AGENT_API_KEY=
AGENT_BASE_URL=https://api.openai.com/v1
AGENT_TIMEOUT_SECONDS=20
AGENT_MAX_ATTEMPTS=2
AGENT_FALLBACKS_JSON=[]
# Optional provider fallback keys (used when AGENT_API_KEY is empty)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=

# -----------------------------
# Skills lifecycle
# -----------------------------
# Optional override for tool/file working directory.
# If unset, local CLI/TUI/API runs use the process startup directory.
WORKING_DIR=
ACTIVE_SKILLS_DIR=
CUSTOMIZED_SKILLS_DIR=
SKILLS_DIR=

# -----------------------------
# Tool runtime profile
# -----------------------------
# Recommended default for local testing:
# minimal | external_operation | full
TOOLS_PROFILE=external_operation
TOOLS_NAMESAKE_STRATEGY=skip
ENABLE_ECHO_TOOL=false
ENABLE_EXEC_TOOL=false
TEAMBOT_EXEC_TIMEOUT_SECONDS=20
TEAMBOT_BROWSER_TIMEOUT_SECONDS=10
TEAMBOT_TOOL_OUTPUT_MAX_CHARS=4000

# -----------------------------
# MCP runtime
# -----------------------------
MCP_ENABLED=false
MCP_SERVERS_JSON=[]

# -----------------------------
# Policy gate
# -----------------------------
ALLOW_HIGH_RISK_ACTIONS=false
HIGH_RISK_ALLOWED_ACTIONS=
