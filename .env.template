# -----------------------------
# Provider manager (agent role)
# -----------------------------
AGENT_PROVIDER=openai-compatible
AGENT_MODEL=
AGENT_API_KEY=
AGENT_BASE_URL=https://api.openai.com/v1
AGENT_TIMEOUT_SECONDS=20
AGENT_MAX_ATTEMPTS=2
AGENT_FALLBACKS_JSON=[]

# -----------------------------
# Optional router role (advanced; disabled by default)
# -----------------------------
ROUTER_PROVIDER=
ROUTER_MODEL=
ROUTER_API_KEY=
ROUTER_BASE_URL=
ROUTER_TIMEOUT_SECONDS=10
ROUTER_MAX_ATTEMPTS=2
ROUTER_FALLBACKS_JSON=[]

# -----------------------------
# Skills lifecycle
# -----------------------------
WORKING_DIR=~/.teambot
ACTIVE_SKILLS_DIR=
CUSTOMIZED_SKILLS_DIR=
SKILLS_DIR=

# -----------------------------
# Tool toggles
# -----------------------------
ENABLE_ECHO_TOOL=false
ENABLE_EXEC_TOOL=false

# -----------------------------
# Policy gate
# -----------------------------
ALLOW_HIGH_RISK_ACTIONS=false
HIGH_RISK_ALLOWED_ACTIONS=
